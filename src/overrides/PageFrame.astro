---
import MobileMenuToggle from "virtual:starlight/components/MobileMenuToggle";

const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="page-wrapper">
  <div class="page sl-flex">
    <header class="header"><slot name="header" /></header>
    <div class="page-body sl-flex">
      {
        hasSidebar && (
          <nav
            class="sidebar print:hidden"
            aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}
          >
            <MobileMenuToggle />
            <div id="starlight__sidebar" class="sidebar-pane">
              <div class="sidebar-content sl-flex">
                <slot name="sidebar" />
              </div>
            </div>
          </nav>
        )
      }
      <div class="main-frame"><slot /></div>
    </div>
  </div>
</div>

<style>
  @layer starlight.core {
    .page-wrapper {
      max-width: 90rem;
      margin: 0 auto;
      width: 100%;
      padding-inline: var(--sl-nav-pad-x);
      min-height: 100vh;
    }

    .page {
      flex-direction: column;
      min-height: 100vh;
    }

    .page-body {
      flex: 1;
      flex-direction: column;
      min-width: 0;
    }

    .header {
      z-index: var(--sl-z-index-navbar);
      position: sticky;
      top: 0;
      width: 100%;
      box-sizing: border-box;
      height: var(--sl-nav-height);
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      padding: var(--sl-nav-pad-y) 0;
      background-color: var(--sl-color-bg-nav);
    }

    :global([data-has-sidebar]) .header {
      /* Reserve space for the mobile menu button so the search icon remains visible */
      padding-inline-end: calc(
        var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size)
      );
    }

    .sidebar-pane {
      visibility: var(--sl-sidebar-visibility, hidden);
      position: fixed;
      z-index: var(--sl-z-index-menu);
      inset-block: var(--sl-nav-height) 0;
      inset-inline-start: 0;
      width: 100%;
      background-color: var(--sl-color-black);
      overflow-y: auto;
    }

    :global([aria-expanded="true"]) ~ .sidebar-pane {
      --sl-sidebar-visibility: visible;
    }

    .sidebar-content {
      height: 100%;
      min-height: max-content;
      padding: 1.5rem var(--sl-sidebar-pad-x) 0;
      padding-inline-start: 0;
      flex-direction: column;
      gap: 1rem;
    }

    @media (min-width: 50rem) {
      .sidebar-content::after {
        content: "";
        padding-bottom: 1px;
      }
    }

    .main-frame {
      padding-top: var(--sl-mobile-toc-height);
      padding-inline-start: var(--sl-content-inline-start);
    }

    @media (min-width: 50rem) {
      .page-body {
        flex-direction: row;
        align-items: flex-start;
        padding-top: 1.5rem;
      }

      :global([data-has-sidebar]) .header {
        padding-inline-end: 0;
      }

      .sidebar {
        flex-shrink: 0;
        width: var(--sl-sidebar-width);
        min-width: var(--sl-sidebar-width);
      }

      .sidebar-pane {
        --sl-sidebar-visibility: visible;
        position: fixed;
        top: var(--sl-nav-height);
        bottom: 0;
        left: max(
          var(--sl-nav-pad-x),
          calc((100vw - 90rem) / 2 + var(--sl-nav-pad-x))
        );
        width: var(--sl-sidebar-width);
        min-width: var(--sl-sidebar-width);
        max-height: calc(100vh - var(--sl-nav-height));
        background-color: var(--sl-color-bg-sidebar);
      }

      .main-frame {
        flex: 1;
        min-width: 0;
        padding-top: var(--sl-mobile-toc-height);
        padding-inline-start: var(--sl-content-pad-x);
      }
    }
  }
</style>
