---
import type { SidebarGroup } from "@/types/sidebar";
import { checkIsCurrent, slugify } from "@/utils/sidebar";
import SidebarLink from "./SidebarLink.astro";
import ArrowIcon from "@/assets/arrow.svg";
import Badge from "./Badge.astro";

export interface Props extends SidebarGroup {
  parentId?: string;
}

const { label, entries, collapsed, badge, parentId } = Astro.props;

const expanded = !collapsed || checkIsCurrent(entries);
const id = slugify(parentId, label, badge && badge.text);
const buttonId = slugify(id, "button");
const dropdownId = slugify(id, "dropdown");
---

<div x-data={`{ isOpen: ${expanded} }`} class="w-full">
  <button
    @click="isOpen = !isOpen"
    class="leading-5 text-sm! py-[3px] px-[5px] flex items-center justify-between w-48"
    aria-expanded={expanded}
    :aria-expanded="isOpen"
    id={buttonId}
    aria-controls={dropdownId}
  >
    <span>{label}</span>
    <span class="flex items-center gap-1">
      {badge && <Badge {...badge} />}
      <span
        class="inline-flex transition duration-200"
        :class="{ 'rotate-90': isOpen, 'rotate-0': !isOpen }"
      >
        <ArrowIcon class="fill-zinc-300 size-3" />
      </span>
    </span>
  </button>
  <div class="pl-2.5">
    <ul
      {...!expanded ? { "x-cloak": true } : {}}
      x-show="isOpen"
      x-transition
      class="border-l-[0.3px] border-l-zinc-300 py-1.5 pl-1.5 flex flex-col gap-y-1"
      id={dropdownId}
    >
      {
        entries.map((entry) => (
          <li>
            {entry.type === "link" ? (
              <SidebarLink {...entry} parentId={id} />
            ) : (
              <SidebarGroup {...entry} parentId={id} />
            )}
          </li>
        ))
      }
    </ul>
  </div>
</div>
